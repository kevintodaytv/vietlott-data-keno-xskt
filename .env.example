# ══════════════════════════════════════════════════════════════════
#   .env — Alien-Nexus Environment Configuration
#   Copy file này thành .env và điền thông tin thật
# ══════════════════════════════════════════════════════════════════

# ── DEPLOY ─────────────────────────────────────────────────────
DEPLOY_ENV=production

# ── DISCORD WEBHOOK ────────────────────────────────────────────
# Lấy từ: Server Settings → Integrations → Webhooks → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# ── TELEGRAM ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# ── SLACK ──────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/URL

# ── OVERLORD AGENT ─────────────────────────────────────────────
OVERLORD_HEARTBEAT_MINUTES=30
QA_SCREENSHOT_DIR=/tmp/qa_screenshots
AUDIT_UI_URL=http://nexus_ui:3000

# ── REDIS ──────────────────────────────────────────────────────
REDIS_URL=redis://vault_memory:6379

# ── SUPABASE ────────────────────────────────────────────────
# Lấy từ: https://supabase.com/dashboard → Project → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY_HERE
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ── DESIGN SYSTEM ───────────────────────────────────────────
# DESIGN.md: awesome-design-md / supabase (dark emerald theme)
# Source: https://github.com/VoltAgent/awesome-design-md
DESIGN_THEME=supabase
