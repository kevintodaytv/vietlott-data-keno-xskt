# ==============================================================
# Biến môi trường cho Overlord Webhook Module
# Copy file này thành .env và điền thông tin thật
# ==============================================================

# ── DISCORD ────────────────────────────────────────────────────
# Lấy từ: Server Settings → Integrations → Webhooks → Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# ── TELEGRAM ───────────────────────────────────────────────────
# Bot Token: @BotFather → /newbot → copy token
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
# Chat ID: Gửi tin nhắn cho bot rồi gọi API getUpdates để lấy chat_id
# Hoặc dùng @userinfobot để lấy ID của bạn
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_OR_GROUP_ID

# ── SLACK ──────────────────────────────────────────────────────
# Lấy từ: api.slack.com/apps → Incoming Webhooks → Activate → Copy URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# ── QA SNIPER CONFIG ───────────────────────────────────────────
# Thư mục lưu ảnh chụp màn hình
QA_SCREENSHOT_DIR=/tmp/qa_screenshots
# URL giao diện cần kiểm toán
AUDIT_UI_URL=http://localhost:3000

# ── OVERLORD AGENT CONFIG ──────────────────────────────────────
# Tự động audit mỗi 30 phút (heartbeat)
OVERLORD_HEARTBEAT_MINUTES=30
# Môi trường deploy (hiển thị trong báo cáo)
DEPLOY_ENV=production
